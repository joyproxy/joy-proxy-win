<Window x:Class="JoyProxy.ProcessPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择运行中的进程" Height="520" Width="820"
        MinHeight="420" MinWidth="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="选择要代理的目标程序（按 exe 路径匹配）"
                   Margin="0,0,0,8" Foreground="#666"/>

        <DockPanel Grid.Row="1" Margin="0,0,0,8">
            <Button DockPanel.Dock="Right" Content="刷新" Click="Refresh_Click"
                    Padding="14,6" Margin="8,0,0,0"/>
            <TextBox x:Name="FilterBox" Padding="6,4"
                     TextChanged="FilterBox_TextChanged"
                     ToolTip="按进程名或路径过滤"/>
        </DockPanel>

        <ListBox x:Name="ProcessList" Grid.Row="2"
                 SelectionChanged="ProcessList_SelectionChanged"
                 DisplayMemberPath="Display"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="确定" Click="Ok_Click" Padding="18,8" Margin="0,0,8,0" IsDefault="True"/>
            <Button Content="取消" Click="Cancel_Click" Padding="18,8" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
